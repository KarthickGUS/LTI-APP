<style>
  .layout-container {
    font-family: "Lato", "Helvetica Neue", Helvetica, Arial, sans-serif;
    background: #f5f5f5;
    padding: 20px;
  }

  .filter-bar {
    background: #ffffff;
    padding: 15px;
    border: 1px solid #ddd;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .select-field {
    padding: 8px;
    border: 1px solid #c7cdd1;
    border-radius: 3px;
    min-width: 250px;
  }

  .btn-primary {
    background: #0374b5;
    color: white;
    border: none;
    padding: 8px 12px;
    border-radius: 3px;
    cursor: pointer;
  }

  .btn-secondary {
    background: #e0e0e0;
    padding: 8px 12px;
    border-radius: 3px;
    text-decoration: none;
    color: black;
  }

  .btn-export {
    background: #2d3b45;
    color: white;
    border: none;
    padding: 8px 14px;
    border-radius: 3px;
    cursor: pointer;
    margin-left: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
  }

  .data-table th {
    text-align: left;
    background: #f5f5f5;
    padding: 10px;
    border-bottom: 1px solid #ddd;
  }

  .data-table td {
    padding: 10px;
    border-bottom: 1px solid #eee;
  }

  .url-col {
    width: 400px !important;

    overflow-wrap: anywhere;
  }

  #prev_btn {
    cursor: pointer;
  }

  .wide-table th,
  .wide-table td {
    padding: 10px;
  }

  .card-container {
    background: #fff;
    border: 1px solid #ddd;
    margin-bottom: 25px;
    border-radius: 4px;
  }

  /* Header */
  .card-header {
    padding: 15px;
    border-bottom: 1px solid #eee;
  }

  .card-header h2 {
    margin: 0 0 10px 0;
  }

  .card-body {
    padding: 15px;
    height: 50%;   /* ✅ reduced from 400px */
    display: flex;
    flex-direction: column;
  }

  .table-wrapper {
    overflow: auto;
    flex: 1;               /* ✅ take remaining space */
  }

  #pagination_controls {
    margin-top: 40px;
    margin-left: 80%;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;   /* ✅ important */
  }

  .data-table th,
  .data-table td {
    padding: 10px;
    width: 150px;

    white-space: normal;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .small-col {
    width: 100px;
    text-align: center;
  }

  .time-col {
    width: 180px !important;
  }
</style>

<div class="layout-container">

  <div class="card-container">

    <div class="card-header">
      <h2>Page View History</h2>

      <div class="filter-bar">
        <label>User</label>

        <select id="user_select" class="select-field">
          <option value="">Select User</option>
          <% @users.each do |user| %>
            <option value="<%= user[:id] %>"><%= user[:name] %></option>
          <% end %>
        </select>

        <button id="export_btn" class="btn-export">Export</button>
      </div>
    </div>

    <div class="card-body">

      <div class="table-wrapper">
        <table class="data-table wide-table">
          <thead>
            <tr>
              <th class="url-col">URL</th>
              <th>Course Name</th>
              <th>Context Type</th>
              <th>Controller</th>
              <th>Action</th>
              <th class="small-col">Interaction</th>
              <th class="time-col">Visited Time</th>
              <th class="small-col">Participated</th>
              <th class="small-col">Contributed</th>
              <th class="small-col">Summarized</th>
              <th>Access ID</th>
              <th>App Name</th>
              <th>User Request</th>
              <th>Render Time</th>
            </tr>
          </thead>
          <tbody id="page_views_table">
            <tr>
              <td colspan="6">Select a user</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div id="pagination_controls">
        <button id="prev_btn" class="btn-secondary" disabled>Prev</button>
        <span id="page_info">Page 1</span>
        <button id="next_btn" class="btn-primary">Next</button>
      </div>

    </div>
  </div>


  <div class="card-container">

    <div class="card-header">
      <h2>Grade History</h2>
    </div>

    <div class="card-body">

      <div class="table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>Assignment</th>
              <th>Course</th>
              <th>Score</th>
              <th>Grade</th>
              <th>Grader</th>
              <th>Graded At</th>
            </tr>
          </thead>
          <tbody id="grade_table">
            <tr>
              <td colspan="6">Select a user</td>
            </tr>
          </tbody>
        </table>
      </div>

    </div>
  </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

<script>

  $('#export_btn').on('click', function () {

    let table = document.querySelector(".data-table");
    let rows = table.querySelectorAll("tr");

    let data = [];

    rows.forEach((row, index) => {
      let cols = row.querySelectorAll("th, td");
      let rowData = [];

      cols.forEach(col => {
        rowData.push(col.innerText.trim());
      });

      data.push(rowData);
    });

    if (data.length <= 1) {
      alert("No data to export");
      return;
    }

    // Create worksheet
    let ws = XLSX.utils.aoa_to_sheet(data);

    // Create workbook
    let wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, "Page Views");

    // Download
    XLSX.writeFile(wb, "page_views.xlsx");
  });

</script>

<script>
  let currentPage = 1;
  let currentUserId = null;

  $('#user_select').on('change', function () {
    currentUserId = $(this).val();
    currentPage = 1;

    if (!currentUserId) return;

    loadPage(currentPage);
    loadGradeHistory(currentUserId, 34); 
  });

  $('#next_btn').on('click', function () {
    currentPage += 1;
    loadPage(currentPage);
  });

  $('#prev_btn').on('click', function () {
    if (currentPage > 1) {
      currentPage -= 1;
      loadPage(currentPage);
    }
  });

  function loadPage(page) {

    $('#page_views_table').html('<tr><td colspan="4">Loading...</td></tr>');

    $.ajax({
      url: '/accounts/page_views',
      method: 'GET',
      data: {
        user_id: currentUserId,
        page: page
      },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (res) {

        let data = res.data || [];

        if (data.length === 0) {
          $('#page_views_table').html('<tr><td colspan="4">No data found</td></tr>');
          return;
        }

        let rows = '';

        $.each(data, function (i, pv) {
          rows += `
            <tr>
              <td class="url-col">${pv.url || ''}</td>
              <td>${pv.course_name || '-'}</td>
              <td>${pv.context_type || ''}</td>
              <td>${pv.controller || ''}</td>
              <td>${pv.action || ''}</td>
              <td>${pv.interaction_seconds || 0}</td>
              <td>${pv.created_at || ''}</td>
              <td>${pv.participated ? 'Yes' : 'No'}</td>
              <td>${pv.contributed ? 'Yes' : 'No'}</td>
              <td>${pv.summarized ? 'Yes' : 'No'}</td>
              <td>${pv.asset_user_access_id || ''}</td>
              <td>${pv.app_name}</td>
              <td>${pv.user_request}</td>
              <td>${pv.render_time}</td>
            </tr>
          `;
        });

        $('#page_views_table').html(rows);

        $('#page_info').text(`Page ${res.current_page}`);

        // ✅ Enable / Disable buttons
        $('#prev_btn').prop('disabled', !res.has_prev);
        $('#next_btn').prop('disabled', !res.has_next);
      },

      error: function () {
        $('#page_views_table').html('<tr><td colspan="4">Error loading data</td></tr>');
      }
    });
  }
  
  function loadGradeHistory(userId, courseId) {

    $('#grade_table').html('<tr><td colspan="6">Loading...</td></tr>');

    $.ajax({
      url: '/accounts/grade_history',
      method: 'GET',
      data: {
        user_id: userId,
        course_id: courseId
      },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (data) {

        if (!data || data.length === 0) {
          $('#grade_table').html('<tr><td colspan="6">No data found</td></tr>');
          return;
        }

        let rows = '';

        $.each(data, function (i, g) {
          rows += `
            <tr>
              <td>${g.assignment_name || ''}</td>
              <td>${g.course_name || ''}</td>
              <td>${g.score || 0}</td>
              <td>${g.grade || ''}</td>
              <td>${g.grader || ''}</td>
              <td>${g.graded_at || ''}</td>
            </tr>
          `;
        });

        $('#grade_table').html(rows);
      },

      error: function () {
        $('#grade_table').html('<tr><td colspan="6">Error loading data</td></tr>');
      }
    });
  }
</script>