<style>
  .layout-container {
    font-family: "Lato", "Helvetica Neue", Helvetica, Arial, sans-serif;
    background: #f5f5f5;
    padding: 20px;
  }

  .filter-bar {
    background: #ffffff;
    padding: 15px;
    border: 1px solid #ddd;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .select-field {
    padding: 8px;
    border: 1px solid #c7cdd1;
    border-radius: 3px;
    min-width: 250px;
  }

  .btn-primary {
    background: #0374b5;
    color: white;
    border: none;
    padding: 8px 12px;
    border-radius: 3px;
    cursor: pointer;
  }

  .btn-secondary {
    background: #e0e0e0;
    padding: 8px 12px;
    border-radius: 3px;
    text-decoration: none;
    color: black;
  }

  .btn-export {
    background: #2d3b45;
    color: white;
    border: none;
    padding: 8px 14px;
    border-radius: 3px;
    cursor: pointer;
    margin-left: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
  }

  .data-table th {
    text-align: left;
    background: #f5f5f5;
    padding: 10px;
    border-bottom: 1px solid #ddd;
  }

  .data-table td {
    padding: 10px;
    border-bottom: 1px solid #eee;
  }

  .url-col {
    width: 400px !important;

    overflow-wrap: anywhere;
  }

  #prev_btn {
    cursor: pointer;
  }

  .wide-table th,
  .wide-table td {
    padding: 10px;
  }

  .card-container {
    background: #fff;
    border: 1px solid #ddd;
    margin-bottom: 25px;
    border-radius: 4px;
  }

  /* Header */
  .card-header {
    padding: 15px;
    border-bottom: 1px solid #eee;
  }

  .card-header h2 {
    margin: 0 0 10px 0;
  }

  .card-body {
    padding: 15px;
    height: 50%;   /* ✅ reduced from 400px */
    display: flex;
    flex-direction: column;
  }

  .table-wrapper {
    overflow: auto;
    flex: 1;               /* ✅ take remaining space */
  }

  #pagination_controls {
    margin-top: 40px;
    margin-left: 80%;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;   /* ✅ important */
  }

  .data-table th,
  .data-table td {
    padding: 10px;
    width: 150px;

    white-space: normal;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .small-col {
    width: 100px;
    text-align: center;
  }

  .time-col {
    width: 180px !important;
  }
</style>

<div class="layout-container">

  <div class="card-container">

    <div class="card-header">
      <h2>Page View History</h2>

    </div>

    <div class="card-body">
      <div class="filter-bar">
        <label>User</label>

        <select id="user_select" class="select-field">
          <option value="">Select User</option>
          <% @users.each do |user| %>
            <option value="<%= user[:id] %>"><%= user[:name] %></option>
          <% end %>
        </select>

        <button id="export_btn" class="btn-export">Export</button>
      </div>

      <div class="table-wrapper">
        <table class="data-table wide-table">
          <thead>
            <tr>
              <th>Course Name</th>
              <th>Context</th>
              <th>Page</th>
              <th class="url-col">URL</th>
              <th>Action</th>
              <th class="small-col">Interaction (sec)</th>
              <th class="time-col">Visited Time</th>
              <th class="small-col">Participated</th>
              <th class="small-col">Contributed</th>
              <th>Render Time(sec )</th>
            </tr>
          </thead>
          <tbody id="page_views_table">
            <tr>
              <td colspan="6">Select a user</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div id="pagination_controls">
        <button id="prev_btn" class="btn-secondary" disabled>Prev</button>
        <span id="page_info">Page 1</span>
        <button id="next_btn" class="btn-primary">Next</button>
      </div>

    </div>
  </div>


  <div class="card-container">

    <div class="card-header">
      <h2>Grade History</h2>
    </div>

    <div class="card-body">
      <div class="filter-bar">
        <label>User</label>

        <select id="grade_user_select" class="select-field">
          <option value="">Select User</option>
          <% @users.each do |user| %>
            <option value="<%= user[:id] %>"><%= user[:name] %></option>
          <% end %>
        </select>

        <select id="course_select" class="select-field">
          <option value="">Select Course</option>
        </select>

      <button id="graph_btn" class="btn-primary" style="margin-left:10px;">
        📊 View Graph
      </button>

        <button id="export_btn" class="btn-export">Export</button>
      </div>

      <div class="table-wrapper" id="table_views">
        <table class="data-table">
        <thead>
          <tr>
            <th>Assignment</th>
            <th>Points Possible</th>
            <th>Max Score</th>
            <th>Min Score</th>
            <th>Median</th>
            <th>On Time</th>
            <th>Late</th>
          </tr>
        </thead>
          <tbody id="grade_table">
            <tr>
              <td colspan="6">Select a user</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div id="graph_container" style="display:none; height:400px;">
        <canvas id="pageViewChart"></canvas>
      </div>

    </div>
  </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

  $('#export_btn').on('click', function () {

    let pageTable = document.querySelector("#page_views_table");
    let pageHeaders = document.querySelectorAll(".data-table thead tr th");

    let pageData = [];

    let headerRow = [];
    pageHeaders.forEach(th => headerRow.push(th.innerText.trim()));
    pageData.push(headerRow);

    pageTable.querySelectorAll("tr").forEach(row => {
      let rowData = [];
      row.querySelectorAll("td").forEach(td => {
        rowData.push(td.innerText.trim());
      });
      if (rowData.length) pageData.push(rowData);
    });

    let gradeTable = document.querySelector("#grade_table");

    let gradeHeaders = [
      "Assignment",
      "Course",
      "Score",
      "Grade",
      "Grader",
      "Graded At"
    ];

    let gradeData = [gradeHeaders];

    gradeTable.querySelectorAll("tr").forEach(row => {
      let rowData = [];
      row.querySelectorAll("td").forEach(td => {
        rowData.push(td.innerText.trim());
      });
      if (rowData.length) gradeData.push(rowData);
    });

    let wb = XLSX.utils.book_new();

    let ws1 = XLSX.utils.aoa_to_sheet(pageData);
    ws1['!cols'] = [
      { wch: 45 }, // URL
      { wch: 25 },
      { wch: 20 },
      { wch: 20 },
      { wch: 20 },
      { wch: 15 },
      { wch: 25 },
      { wch: 15 },
      { wch: 15 },
      { wch: 15 },
      { wch: 20 },
      { wch: 20 },
      { wch: 30 },
      { wch: 20 }
    ];

    XLSX.utils.book_append_sheet(wb, ws1, "Page Views");

    let ws2 = XLSX.utils.aoa_to_sheet(gradeData);
    ws2['!cols'] = [
      { wch: 30 },
      { wch: 25 },
      { wch: 15 },
      { wch: 15 },
      { wch: 30 },
      { wch: 25 }
    ];

    XLSX.utils.book_append_sheet(wb, ws2, "Grade History");

    XLSX.writeFile(wb, "canvas_report.xlsx");

  });

</script>

<script>
  let currentPage = 1;
  let currentUserId = null;

  $('#user_select').on('change', function () {
    currentUserId = $(this).val();
    currentPage = 1;

    if (!currentUserId) return;

    loadPage(currentPage);
  });

  $('#grade_user_select').on('change', function () {
    const userId = $(this).val();

    if (!userId) return;

    $('#course_select').html('<option value="">Loading courses...</option>');

    $.ajax({
      url: '/accounts/courses',   // backend endpoint
      method: 'GET',
      data: { user_id: userId },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (data) {

        let options = '<option value="">Select Course</option>';

        $.each(data, function (i, course) {
          options += `<option value="${course.id}">${course.name}</option>`;
        });

        $('#course_select').html(options);
      },

      error: function () {
        $('#course_select').html('<option>Error loading courses</option>');
      }
    });
  });

  $('#next_btn').on('click', function () {
    currentPage += 1;
    loadPage(currentPage);
  });

  $('#prev_btn').on('click', function () {
    if (currentPage > 1) {
      currentPage -= 1;
      loadPage(currentPage);
    }
  });

  function loadPage(page) {

    $('#page_views_table').html('<tr><td colspan="4">Loading...</td></tr>');

    $.ajax({
      url: '/accounts/page_views',
      method: 'GET',
      data: {
        user_id: currentUserId,
        page: page
      },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (res) {

        let data = res.data || [];

        if (data.length === 0) {
          $('#page_views_table').html('<tr><td colspan="4">No data found</td></tr>');
          return;
        }

        let rows = '';

        $.each(data, function (i, pv) {

          let visitedTime = '';
          if (pv.created_at) {
            let date = new Date(pv.created_at);

            visitedTime = date.toLocaleString(undefined, {
              year: 'numeric',
              month: 'short',
              day: '2-digit',
              hour: '2-digit',
              minute: '2-digit',
              hour12: true
            });
          }

          let renderTime = pv.render_time
            ? (parseFloat(pv.render_time) * 1000).toFixed(3)
            : '0.000';

          rows += `
            <tr>
              <td>${pv.course_name || '-'}</td>
              <td>${pv.context_type || ''}</td>
              <td>${pv.controller || ''}</td>
              <td class="url-col">${pv.url || ''}</td>
              <td>${pv.action || ''}</td>
              <td class="small-col">${pv.interaction_seconds || 0}</td>
              <td class="time-col">${visitedTime}</td>
              <td class="small-col">${pv.participated ? 'Yes' : 'No'}</td>
              <td class="small-col">${pv.contributed ? 'Yes' : 'No'}</td>
              <td>${renderTime}</td>
            </tr>
          `;
        });

        $('#page_views_table').html(rows);

        $('#page_info').text(`Page ${res.current_page}`);

        $('#prev_btn').prop('disabled', !res.has_prev);
        $('#next_btn').prop('disabled', !res.has_next);
      },

      error: function () {
        $('#page_views_table').html('<tr><td colspan="4">Error loading data</td></tr>');
      }
    });
  }
  
  function loadAssignmentAnalytics(courseId) {

    $('#grade_table').html('<tr><td colspan="7">Loading...</td></tr>');
    const userId = $('#grade_user_select').val();

    $.ajax({
      url: '/accounts/assignment_analytics',
      method: 'GET',
      data: { course_id: courseId, user_id: userId },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (data) {

        if (!data || data.length === 0) {
          $('#grade_table').html('<tr><td colspan="7">No data found</td></tr>');
          return;
        }

        let rows = '';

        $.each(data, function (i, a) {

          rows += `
            <tr>
              <td>${a.title || ''}</td>
              <td>${a.points_possible || 0}</td>
              <td>${a.max_score || 0}</td>
              <td>${a.min_score || 0}</td>
              <td>${a.median || 0}</td>
              <td>${a.submission?.score || 0}</td>
              <td>${a.status || '-'}</td>
            </tr>
          `;
        });

        $('#grade_table').html(rows);
      },

      error: function () {
        $('#grade_table').html('<tr><td colspan="7">Error loading data</td></tr>');
      }
    });
  }

  $('#course_select').on('change', function () {
    const courseId = $(this).val();

    if (!courseId) return;

    loadAssignmentAnalytics(courseId);
  });
</script>

<script>
  let chartInstance = null;

  $("#graph_btn").click(function () {

    const courseId = $("#course_select").val();
    const userId = $("#grade_user_select").val();

    if (!courseId) {
      alert("Please select a course");
      return;
    }

    document.getElementById("table_views").style.display = "none";

    $("#graph_container")
      .show()
      .html('<canvas id="assignmentChart"></canvas>');

    $.ajax({
      url: '/accounts/assignment_analytics',
      method: "GET",
      data: { course_id: courseId, user_id: userId },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (data) {

        console.log("API RESPONSE:", data); // ✅ debug

        // 🚨 HANDLE ERROR RESPONSE
        if (data.errors) {
          $("#graph_container").html(data.errors[0].message);
          return;
        }

        // 🚨 HANDLE EMPTY / INVALID
        if (!Array.isArray(data) || data.length === 0) {
          $("#graph_container").html("No data available");
          return;
        }

        let labels = [];
        let scores = [];
        let maxScores = [];

        data.forEach(a => {

          // skip invalid records
          if (!a.title) return;

          labels.push(a.title);

          scores.push(a.submission?.score ?? 0);
          maxScores.push(a.max_score ?? 0);
        });

        // 🚨 if all empty
        if (labels.length === 0) {
          $("#graph_container").html("No valid data");
          return;
        }

        renderChart(labels, scores, maxScores);
      },

      error: function (err) {
        console.error(err);
        $("#graph_container").html("Error loading chart");
      }
    });
  });


  function renderChart(labels, scores, maxScores) {

    const canvas = document.getElementById("assignmentChart");

    if (!canvas) return;

    const ctx = canvas.getContext("2d");

    if (chartInstance) {
      chartInstance.destroy();
    }

    chartInstance = new Chart(ctx, {
      type: "bar",
      data: {
        labels: labels,
        datasets: [
          {
            label: "User Score",
            data: scores,
            borderWidth: 2
          },
          {
            label: "Max Score",
            data: maxScores,
            borderWidth: 2
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false, // ✅ FIX layout issues
        plugins: {
          legend: {
            display: true
          }
        },
        scales: {
          x: {
            ticks: {
              maxRotation: 45,
              minRotation: 45,
              autoSkip: false
            }
          },
          y: {
            beginAtZero: true
          }
        }
      }
    });
  }
</script>