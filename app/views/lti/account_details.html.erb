<style>
  .layout-container {
    font-family: "Lato", "Helvetica Neue", Helvetica, Arial, sans-serif;
    background: #f5f5f5;
    padding: 20px;
  }

  .filter-bar {
    background: #ffffff;
    padding: 15px;
    border: 1px solid #ddd;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .select-field {
    padding: 8px;
    border: 1px solid #c7cdd1;
    border-radius: 3px;
    min-width: 250px;
  }

  .btn-primary {
    background: #0374b5;
    color: white;
    border: none;
    padding: 8px 12px;
    border-radius: 3px;
    cursor: pointer;
  }

  .btn-secondary {
    background: #e0e0e0;
    padding: 8px 12px;
    border-radius: 3px;
    text-decoration: none;
    color: black;
  }

  .btn-export {
    background: #2d3b45;
    color: white;
    border: none;
    padding: 8px 14px;
    border-radius: 3px;
    cursor: pointer;
    margin-left: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
  }

  .data-table th {
    text-align: left;
    background: #f5f5f5;
    padding: 10px;
    border-bottom: 1px solid #ddd;
  }

  .data-table td {
    padding: 10px;
    border-bottom: 1px solid #eee;
  }

  .url-col {
    width: 400px !important;

    overflow-wrap: anywhere;
  }

  #prev_btn {
    cursor: pointer;
  }

  .wide-table th,
  .wide-table td {
    padding: 10px;
  }

  .card-container {
    background: #fff;
    border: 1px solid #ddd;
    margin-bottom: 25px;
    border-radius: 4px;
  }

  /* Header */
  .card-header {
    padding: 15px;
    border-bottom: 1px solid #eee;
  }

  .card-header h2 {
    margin: 0 0 10px 0;
  }

  .card-body {
    padding: 15px;
    height: 50%;   /* ✅ reduced from 400px */
    display: flex;
    flex-direction: column;
  }

  .table-wrapper {
    overflow: auto;
    flex: 1;               /* ✅ take remaining space */
  }

  #pagination_controls {
    margin-top: 40px;
    margin-left: 80%;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;   /* ✅ important */
  }

  .data-table th,
  .data-table td {
    padding: 10px;
    width: 150px;

    white-space: normal;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .small-col {
    width: 100px;
    text-align: center;
  }

  .time-col {
    width: 180px !important;
  }

  .chart-wrapper {
    position: relative;
    height: 300px;   /* ✅ FIXED HEIGHT */
    width: 100%;
  }
</style>

<div class="layout-container">

  <div class="card-container">

    <div class="card-header">
      <h2>Page View History</h2>

    </div>

    <div class="card-body">
      <div class="filter-bar">
        <label>User</label>

        <select id="user_select" class="select-field">
          <option value="">Select User</option>
          <% @users.each do |user| %>
            <option value="<%= user[:id] %>"><%= user[:name] %></option>
          <% end %>
        </select>

        <select id="page_course_select" class="select-field">
          <option value="">Select Course</option>
        </select>

        <button id="export_btn" class="btn-export">Export</button>
      </div>

      <div class="card-container" style="margin-top:20px;">
        <div class="card-header">
          <h3>Overall Page Views</h3>
        </div>

        <div class="card-body">
          <div class="chart-wrapper">
            <canvas id="summaryChart"></canvas>
          </div>
        </div>
      </div>

      <div class="card-container" style="margin-top:20px;">
        <div class="card-header">
          <h3>Last Week Page Views</h3>
        </div>

        <div class="card-body">
          <div class="chart-wrapper">
            <canvas id="pageViewWeeklyChart"></canvas>
          </div>
        </div>
      </div>

    </div>
  </div>


  <div class="card-container">

    <div class="card-header">
      <h2>Grade History</h2>
    </div>

    <div class="card-body">
      <div class="filter-bar">
        <label>User</label>

        <select id="grade_user_select" class="select-field">
          <option value="">Select User</option>
          <% @users.each do |user| %>
            <option value="<%= user[:id] %>"><%= user[:name] %></option>
          <% end %>
        </select>

        <select id="course_select" class="select-field">
          <option value="">Select Course</option>
        </select>

      <button id="graph_btn" class="btn-primary" style="margin-left:10px;">
        📊 View Graph
      </button>

        <button id="export_btn" class="btn-export">Export</button>
      </div>

      <div class="table-wrapper" id="table_views">
        <table class="data-table">
        <thead>
          <tr>
            <th>Assignment</th>
            <th>Points Possible</th>
            <th>Max Score</th>
            <th>Min Score</th>
            <th>Median</th>
            <th>On Time</th>
            <th>Late</th>
          </tr>
        </thead>
          <tbody id="grade_table">
            <tr>
              <td colspan="6">Select a user</td>
            </tr>
          </tbody>
        </table>
      </div>

    </div>
  </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  function loadWeeklyPageViews(courseId, userId) {

    $.ajax({
      url: '/accounts/user_activity',
      method: 'GET',
      data: {
        course_id: courseId,
        user_id: userId
      },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (res) {

        if (!res.page_views) {
          renderWeeklyChart([], []);
        } 
        const weeklyData = processLast7Days(res.page_views);
        renderWeeklyChart(weeklyData.labels, weeklyData.values);
      },

      error: function () {
        console.error("Error loading activity");
      }
    });
  }

  function loadPage() {

    $.ajax({
      url: '/accounts/page_views',
      method: 'GET',
      data: {
        user_id: currentUserId
      },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (res) {

        let data = res.data || [];

        if (data.length === 0) {
          alert("No data found");
          return;
        }

        let excelData = [];

        excelData.push([
          "Course Name",
          "Context",
          "Page",
          "URL",
          "Action",
          "Interaction (sec)",
          "Visited Time",
          "Participated",
          "Contributed",
          "Render Time (sec)"
        ]);

        $.each(data, function (i, pv) {

          let visitedTime = '';
          if (pv.created_at) {
            let date = new Date(pv.created_at);

            visitedTime = date.toLocaleString(undefined, {
              year: 'numeric',
              month: 'short',
              day: '2-digit',
              hour: '2-digit',
              minute: '2-digit',
              hour12: true
            });
          }

          let renderTime = pv.render_time
            ? (parseFloat(pv.render_time)).toFixed(3)
            : '0.000';

          excelData.push([
            pv.course_name || '-',
            pv.context_type || '',
            pv.controller || '',
            pv.url || '',
            pv.action || '',
            pv.interaction_seconds || 0,
            visitedTime,
            pv.participated ? 'Yes' : 'No',
            pv.contributed ? 'Yes' : 'No',
            renderTime
          ]);
        });

        const ws = XLSX.utils.aoa_to_sheet(excelData);
        const wb = XLSX.utils.book_new();

        XLSX.utils.book_append_sheet(wb, ws, "Page Views");

        XLSX.writeFile(wb, "page_views.xlsx");
      },

      error: function () {
        $('#page_views_table').html('<tr><td colspan="4">Error loading data</td></tr>');
      }
    });
  }
  
  function loadAssignmentAnalytics(courseId) {

    $('#grade_table').html('<tr><td colspan="7">Loading...</td></tr>');
    const userId = $('#grade_user_select').val();

    $.ajax({
      url: '/accounts/assignment_analytics',
      method: 'GET',
      data: { course_id: courseId, user_id: userId },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (data) {

        if (!data || data.length === 0) {
          $('#grade_table').html('<tr><td colspan="7">No data found</td></tr>');
          return;
        }

        let rows = '';

        $.each(data, function (i, a) {

          rows += `
            <tr>
              <td>${a.title || ''}</td>
              <td>${a.points_possible || 0}</td>
              <td>${a.max_score || 0}</td>
              <td>${a.min_score || 0}</td>
              <td>${a.median || 0}</td>
              <td>${a.submission?.score || 0}</td>
              <td>${a.status || '-'}</td>
            </tr>
          `;
        });

        $('#grade_table').html(rows);
      },

      error: function () {
        $('#grade_table').html('<tr><td colspan="7">Error loading data</td></tr>');
      }
    });
  }

  function processLast7Days(pageViews) {

    let labels = [];
    let values = [];

    const today = new Date();

    const startDate = new Date();
    startDate.setDate(today.getDate() - 7);

    for (let i = 0; i < 7; i++) {

      let d = new Date(startDate);
      d.setDate(startDate.getDate() + i);

      let dayLabel = d.toLocaleDateString('en-US', { weekday: 'short' });

      labels.push(dayLabel);

      let count = 0;

      Object.keys(pageViews).forEach(ts => {
        let date = new Date(ts);

        if (
          date.getDate() === d.getDate() &&
          date.getMonth() === d.getMonth() &&
          date.getFullYear() === d.getFullYear()
        ) {
          count += pageViews[ts];
        }
      });

      values.push(count);
    }

    return { labels, values };
  }

  let weeklyChartInstance = null;

  function renderWeeklyChart(labels, data) {

    const ctx = document.getElementById("pageViewWeeklyChart").getContext("2d");

    if (weeklyChartInstance) {
      weeklyChartInstance.destroy();
    }

    weeklyChartInstance = new Chart(ctx, {
      type: 'line', 

      data: {
        labels: labels,
        datasets: [{
          label: 'Page Views',
          data: data,
          fill: true,   // ✅ makes it AREA
          tension: 0.3
        }]
      },

      options: {
        responsive: true,
        maintainAspectRatio: false,  

        plugins: {
          legend: {
            display: true
          }
        },

        scales: {
          x: {
            title: {
              display: true,
              text: 'Days'
            }
          },
          y: {
            beginAtZero: true,
            title: {
              display: true,
              text: 'Page Views Count'
            }
          }
        }
      }
    });
  }
</script>

<script>
  let summaryChart = null;

  function renderSummaryChart(labels, data) {

    const ctx = document.getElementById("summaryChart").getContext("2d");

    if (summaryChart) {
      summaryChart.destroy();
    }

    summaryChart = new Chart(ctx, {
      type: "bar",

      data: {
        labels: labels,
        datasets: [{
          label: "Views",
          data: data,
          borderWidth: 1
        }]
      },

      options: {
        responsive: true,
        maintainAspectRatio: false,

        scales: {
          y: {
            beginAtZero: true
          }
        }
      }
    });
  }
</script>

<script>
  let currentPage = 1;
  let currentUserId = null;

  $('#export_btn').on('click', function () {
    currentUserId = $('#user_select').val();

    if (!currentUserId) return;

    loadPage();
  });

  $('#user_select').on('change', function () {
    const userId = $(this).val();

    if (!userId) return;

    $('#page_course_select').html('<option value="">Loading courses...</option>');

    $.ajax({
      url: '/accounts/courses',   
      method: 'GET',
      data: { user_id: userId },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (res) {
        let data = res.courses;

        let options = '<option value="">Select Course</option>';

        $.each(data, function (i, course) {
          options += `<option value="${course.id}">${course.name}</option>`;
        });

        $('#page_course_select').html(options);

        const summary = res.summary || {};

        const labels = [
          "Courses",
          "Pages",
          "Assignments",
          "Discussions",
          "Gradebook",
          "Calendar",
          "Accounts"
        ];

        const values = [
          summary.courses || 0,
          summary.pages || 0,
          summary.assignments || 0,
          summary.discussions || 0,
          summary.gradebook || 0,
          summary.calendar || 0,
          summary.accounts || 0
        ];

        renderSummaryChart(labels, values);
      },

      error: function () {
        $('#page_course_select').html('<option>Error loading courses</option>');
      }
    });
  });

  $('#grade_user_select').on('change', function () {
    const userId = $(this).val();

    if (!userId) return;

    $('#course_select').html('<option value="">Loading courses...</option>');

    $.ajax({
      url: '/accounts/courses',   
      method: 'GET',
      data: { user_id: userId },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (data) {

        let options = '<option value="">Select Course</option>';

        $.each(data, function (i, course) {
          options += `<option value="${course.id}">${course.name}</option>`;
        });

        $('#course_select').html(options);
      },

      error: function () {
        $('#course_select').html('<option>Error loading courses</option>');
      }
    });
  });

  $('#page_course_select').on('change', function () {

    const courseId = $(this).val();
    const userId = $('#user_select').val();

    if (!courseId || !userId) return;

    loadWeeklyPageViews(courseId, userId);
  });

  $('#course_select').on('change', function () {
    const courseId = $(this).val();

    if (!courseId) return;

    loadAssignmentAnalytics(courseId);
  });
</script>

<script>
  let chartInstance = null;

  $("#graph_btn").click(function () {

    const courseId = $("#course_select").val();
    const userId = $("#grade_user_select").val();

    if (!courseId) {
      alert("Please select a course");
      return;
    }

    document.getElementById("table_views").style.display = "none";

    $("#graph_container")
      .show()
      .html('<canvas id="assignmentChart"></canvas>');

    $.ajax({
      url: '/accounts/assignment_analytics',
      method: "GET",
      data: { course_id: courseId, user_id: userId },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (data) {

        console.log("API RESPONSE:", data); // ✅ debug

        if (data.errors) {
          $("#graph_container").html(data.errors[0].message);
          return;
        }

        if (!Array.isArray(data) || data.length === 0) {
          $("#graph_container").html("No data available");
          return;
        }

        let labels = [];
        let scores = [];
        let maxScores = [];

        data.forEach(a => {

          if (!a.title) return;

          labels.push(a.title);

          scores.push(a.submission?.score ?? 0);
          maxScores.push(a.max_score ?? 0);
        });

        if (labels.length === 0) {
          $("#graph_container").html("No valid data");
          return;
        }

        renderChart(labels, scores, maxScores);
      },

      error: function (err) {
        console.error(err);
        $("#graph_container").html("Error loading chart");
      }
    });
  });


  function renderChart(labels, scores, maxScores) {

    const canvas = document.getElementById("assignmentChart");

    if (!canvas) return;

    const ctx = canvas.getContext("2d");

    if (chartInstance) {
      chartInstance.destroy();
    }

    chartInstance = new Chart(ctx, {
      type: "bar",
      data: {
        labels: labels,
        datasets: [
          {
            label: "User Score",
            data: scores,
            borderWidth: 2
          },
          {
            label: "Max Score",
            data: maxScores,
            borderWidth: 2
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false, // ✅ FIX layout issues
        plugins: {
          legend: {
            display: true
          }
        },
        scales: {
          x: {
            ticks: {
              maxRotation: 45,
              minRotation: 45,
              autoSkip: false
            }
          },
          y: {
            beginAtZero: true
          }
        }
      }
    });
  }
</script>