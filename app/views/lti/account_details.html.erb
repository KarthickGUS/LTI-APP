<style>
  .layout-container {
    font-family: "Lato", "Helvetica Neue", Helvetica, Arial, sans-serif;
    background: #f5f5f5;
    padding: 20px;
  }

  .filter-bar {
    background: #ffffff;
    padding: 15px;
    border: 1px solid #ddd;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .select-field {
    padding: 8px;
    border: 1px solid #c7cdd1;
    border-radius: 3px;
    min-width: 250px;
  }

  .btn-primary {
    background: #0374b5;
    color: white;
    border: none;
    padding: 8px 12px;
    border-radius: 3px;
    cursor: pointer;
  }

  .btn-secondary {
    background: #e0e0e0;
    padding: 8px 12px;
    border-radius: 3px;
    text-decoration: none;
    color: black;
  }

  .btn-export {
    background: #2d3b45;
    color: white;
    border: none;
    padding: 8px 14px;
    border-radius: 3px;
    cursor: pointer;
    margin-left: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
  }

  .data-table th {
    text-align: left;
    background: #f5f5f5;
    padding: 10px;
    border-bottom: 1px solid #ddd;
  }

  .data-table td {
    padding: 10px;
    border-bottom: 1px solid #eee;
  }

  .url-col {
    width: 400px !important;

    overflow-wrap: anywhere;
  }

  #prev_btn {
    cursor: pointer;
  }

  .wide-table th,
  .wide-table td {
    padding: 10px;
  }

  .card-container {
    background: #fff;
    border: 1px solid #ddd;
    margin-bottom: 25px;
    border-radius: 4px;
  }

  /* Header */
  .card-header {
    padding: 15px;
    border-bottom: 1px solid #eee;
  }

  .card-header h2 {
    margin: 0 0 10px 0;
  }

  .card-body {
    padding: 15px;
    height: 50%;   /* ✅ reduced from 400px */
    display: flex;
    flex-direction: column;
  }

  .table-wrapper {
    overflow: auto;
    flex: 1;               /* ✅ take remaining space */
  }

  #pagination_controls {
    margin-top: 40px;
    margin-left: 80%;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;   /* ✅ important */
  }

  .data-table th,
  .data-table td {
    padding: 10px;
    width: 150px;

    white-space: normal;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .small-col {
    width: 100px;
    text-align: center;
  }

  .time-col {
    width: 180px !important;
  }

  .dashboard-row {
    display: flex;
    gap: 20px;
    margin-top: 20px;
    align-items: stretch; /* equal height */
  }

  .card-container {
    flex: 1; /* equal width */
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
  }

  .card-header {
    padding: 12px 16px;
    border-bottom: 1px solid #eee;
    font-weight: 600;
  }

  .card-body {
    flex: 1;
    padding: 10px;
    display: flex;
  }

  .chart-wrapper {
    width: 100%;
    height: 280px; 
  }

  .chart-wrapper canvas {
    width: 100% !important;
    height: 100% !important;
  }

  .hide {
    display: none;
  }
</style>

<div class="layout-container">

  <div class="card-container">

    <div class="card-header hide">
      <h2>Page View History</h2>

    </div>

    <div class="card-body">
      <div class="filter-bar">
        <label>User</label>

        <select id="user_select" class="select-field">
          <option value="">Select User</option>
          <% @users.each do |user| %>
            <option value="<%= user[:id] %>"><%= user[:name] %></option>
          <% end %>
        </select>

        <select id="page_course_select" class="select-field">
          <option value="">Select Course</option>
        </select>

        <button id="export_btn" class="btn-export">Export</button>
      </div>

      <div class="dashboard-row">

        <div class="card-container">
          <div class="card-header">
            <h3>Overall Page Views</h3>
          </div>
          <div class="card-body">
            <div class="chart-wrapper">
              <canvas id="summaryChart"></canvas>
            </div>
          </div>
        </div>

        <div class="card-container">
          <div class="card-header">
            <h3>Last Week Page Views</h3>
          </div>
          <div class="card-body">
            <div class="chart-wrapper">
              <canvas id="pageViewWeeklyChart"></canvas>
            </div>
          </div>
        </div>

        <div class="card-container">
          <div class="card-header">
            <h3>Student Grade Views</h3>
          </div>
          <div class="card-body">
            <div class="chart-wrapper">
              <canvas id="gradeChart"></canvas>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>


  <div class="card-container hide">

    <div class="card-header">
      <h2>Grade History</h2>
    </div>

    <div class="card-body">
      <div class="filter-bar">
        <label>User</label>

        <select id="grade_user_select" class="select-field">
          <option value="">Select User</option>
          <% @users.each do |user| %>
            <option value="<%= user[:id] %>"><%= user[:name] %></option>
          <% end %>
        </select>

        <select id="course_select" class="select-field">
          <option value="">Select Course</option>
        </select>

      <button id="graph_btn" class="btn-primary" style="margin-left:10px; display: none">
        📊 View Graph
      </button>

        <button id="export_btn" class="btn-export">Export</button>
      </div>

      <div class="table-wrapper hide" id="table_views">
        <table class="data-table">
        <thead>
          <tr>
            <th>Assignment</th>
            <th>Points Possible</th>
            <th>Max Score</th>
            <th>Min Score</th>
            <th>Median</th>
            <th>On Time</th>
            <th>Late</th>
          </tr>
        </thead>
          <tbody id="grade_table">
            <tr>
              <td colspan="6">Select a user</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="card-container" style="margin-top:20px;">
        <div class="card-header">
          <h3>Student Grade Views</h3>
        </div>

        <div class="card-body">
          <div class="chart-wrapper">
            <canvas id="gradeChart"></canvas>
          </div>
        </div>
      </div>

    </div>
  </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  function loadWeeklyPageViews(courseId, userId) {

    $.ajax({
      url: '/accounts/user_activity',
      method: 'GET',
      data: {
        course_id: courseId,
        user_id: userId
      },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (res) {
        debugger;

        if (!res.page_views) {
          renderWeeklyChart([], []);
        } 
        const weeklyData = processLast7Days(res.page_views);
        renderWeeklyChart(weeklyData.labels, weeklyData.values);      },

      error: function () {
        console.error("Error loading activity");
      }
    });
  }

  function loadPage() {

    $.ajax({
      url: '/accounts/page_views',
      method: 'GET',
      data: {
        user_id: currentUserId
      },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (res) {

        let data = res.data || [];

        if (data.length === 0) {
          alert("No data found");
          return;
        }

        let excelData = [];

        excelData.push([
          "Course Name",
          "Context",
          "Page",
          "URL",
          "Action",
          "Interaction (sec)",
          "Visited Time",
          "Participated",
          "Contributed",
          "Render Time (sec)"
        ]);

        $.each(data, function (i, pv) {

          let visitedTime = '';
          if (pv.created_at) {
            let date = new Date(pv.created_at);

            visitedTime = date.toLocaleString(undefined, {
              year: 'numeric',
              month: 'short',
              day: '2-digit',
              hour: '2-digit',
              minute: '2-digit',
              hour12: true
            });
          }

          let renderTime = pv.render_time
            ? (parseFloat(pv.render_time)).toFixed(3)
            : '0.000';

          excelData.push([
            pv.course_name || '-',
            pv.context_type || '',
            pv.controller || '',
            pv.url || '',
            pv.action || '',
            pv.interaction_seconds || 0,
            visitedTime,
            pv.participated ? 'Yes' : 'No',
            pv.contributed ? 'Yes' : 'No',
            renderTime
          ]);
        });

        const ws = XLSX.utils.aoa_to_sheet(excelData);
        const wb = XLSX.utils.book_new();

        XLSX.utils.book_append_sheet(wb, ws, "Page Views");

        XLSX.writeFile(wb, "page_views.xlsx");
      },

      error: function () {
        $('#page_views_table').html('<tr><td colspan="4">Error loading data</td></tr>');
      }
    });
  }
  
  let gradeChartInstance = null;

  function loadAssignmentAnalytics(courseId) {

    const userId = $('#user_select').val();

    if (!userId) {
      alert("Select a user");
      return;
    }

    $.ajax({
      url: '/accounts/assignment_analytics',
      method: 'GET',
      data: { course_id: courseId, user_id: userId },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (data) {

        console.log("Grade API:", data);

        // Handle response safety
        let assignments = data;

        if (typeof data === "string") {
          assignments = JSON.parse(data);
        }

        if (!Array.isArray(assignments)) {
          assignments = assignments.data || [];
        }

        if (!assignments || assignments.length === 0) {
          alert("No data found");
          return;
        }

        const labels = [];
        const scores = [];

        assignments.forEach(a => {
          const score = a.submission?.score || 0;
          const max = a.points_possible || a.max_score || 0;

          let percentage = 0;

          if (max > 0) {
            percentage = (score / max) * 100;
          }

          labels.push(a.title || "Untitled");
          scores.push(percentage.toFixed(2));
        });

        renderGradeChart(labels, scores);
      },

      error: function () {
        alert("Error loading data");
      }
    });
  }

  function processLast7Days(pageViews) {

    if (!pageViews || typeof pageViews !== "object") {
      console.error("Invalid pageViews:", pageViews);
      return { labels: [], values: [] };
    }

    let labels = [];
    let values = [];

    const today = new Date();
    const startDate = new Date();
    startDate.setDate(today.getDate() - 6); 

    for (let i = 0; i < 7; i++) {

      let d = new Date(startDate);
      d.setDate(startDate.getDate() + i);

      let dayLabel = d.toLocaleDateString('en-US', { weekday: 'short' });
      labels.push(dayLabel);

      let key = d.toISOString().split('T')[0]; // ✅ "YYYY-MM-DD"

      let count = pageViews[key] || 0;

      values.push(count);
    }

    return { labels, values };
  }

  let weeklyChartInstance = null;

  function renderWeeklyChart(labels, data) {

    const ctx = document.getElementById("pageViewWeeklyChart").getContext("2d");

    if (weeklyChartInstance) {
      weeklyChartInstance.destroy();
    }

    weeklyChartInstance = new Chart(ctx, {
      type: 'line', 

      data: {
        labels: labels,
        datasets: [{
          label: 'Page Views',
          data: data,
          fill: true,   // ✅ makes it AREA
          tension: 0.3
        }]
      },

      options: {
        responsive: true,
        maintainAspectRatio: false,  

        plugins: {
          legend: {
            display: true
          }
        },

        scales: {
          x: {
            title: {
              display: true,
              text: 'Days'
            }
          },
          y: {
            beginAtZero: true,
            title: {
              display: true,
              text: 'Page Views Count'
            }
          }
        }
      }
    });
  }

  function renderGradeChart(labels, scores) {

    const ctx = document.getElementById("gradeChart").getContext("2d");

    if (gradeChartInstance) {
      gradeChartInstance.destroy();
    }

    gradeChartInstance = new Chart(ctx, {
      type: "bar",

      data: {
        labels: labels,
        datasets: [{
          label: "Score (%)",
          data: scores,
          borderWidth: 1,
          barThickness: 30,          // ✅ control bar size
          maxBarThickness: 40
        }]
      },

      options: {
        responsive: true,
        maintainAspectRatio: false,   // ✅ IMPORTANT (same as weekly chart)

        devicePixelRatio: window.devicePixelRatio || 1, // ✅ fix blur

        plugins: {
          legend: {
            display: true,
            labels: {
              boxWidth: 12,   // ✅ smaller legend icon
              font: {
                size: 12
              }
            }
          }
        },

        scales: {
          x: {
            title: {
              display: true,
              text: "Assignments"
            },
            ticks: {
              maxRotation: 45,
              minRotation: 0,
              autoSkip: true
            }
          },

          y: {
            title: {
              display: true,
              text: "Percentage (%)"
            },
            beginAtZero: true,
            max: 100
          }
        }
      }
    });
  }
</script>

<script>
  let summaryChart = null;

  function renderSummaryChart(labels, data) {

    const ctx = document.getElementById("summaryChart").getContext("2d");

    if (summaryChart) {
      summaryChart.destroy();
    }

    summaryChart = new Chart(ctx, {
      type: "bar",

      data: {
        labels: labels,
        datasets: [{
          label: "Views",
          data: data,
          borderWidth: 1
        }]
      },

      options: {
        responsive: true,
        maintainAspectRatio: false,

        scales: {
          y: {
            beginAtZero: true
          }
        }
      }
    });
  }
</script>

<script>
  let currentPage = 1;
  let currentUserId = null;

  $('#export_btn').on('click', function () {

    // ❌ OLD LOGIC (commented)
    /*
    currentUserId = $('#user_select').val();
    if (!currentUserId) return;
    loadPage();
    */

    $.ajax({
      url: '/export_course',
      method: 'GET',
      dataType: 'json',   // EXPECT JSON
      headers: {
        "ngrok-skip-browser-warning": "true"
      },
      success: function (data) {

        console.log("API DATA:", data);
        
        const formattedData = data.map(row => ({
          "Course ID": row.course_id,
          "Course Name": row.course_name,
          "Assignment Group ID": row.assignment_group_id,
          "Assignment Group Name": row.assignment_group_name,
          "Assignment ID": row.assignment_id,
          "Assignment Name": row.assignment_name,
          "Created Date": row.created_date,
          "Start Date": row.start_date,
          "Due Date": row.due_date
        }));

        const worksheet = XLSX.utils.json_to_sheet(formattedData);
        const workbook = XLSX.utils.book_new();

        XLSX.utils.book_append_sheet(workbook, worksheet, "Canvas Export");

        XLSX.writeFile(workbook, "canvas_export.xlsx");
      },
      error: function (xhr) {
        console.error("Error:", xhr.responseText);
        alert("Export failed");
      }
    });

  });

  function formatDate(date) {
    if (!date) return '';
    return new Date(date).toLocaleString();
  }

  $('#user_select').on('change', function () {
    const userId = $(this).val();

    if (!userId) return;

    $('#page_course_select').html('<option value="">Loading courses...</option>');

    $.ajax({
      url: '/accounts/courses',   
      method: 'GET',
      data: { user_id: userId },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (res) {
        let data = res.courses;

        let options = '<option value="">Select Course</option>';

        $.each(data, function (i, course) {
          options += `<option value="${course.id}">${course.name}</option>`;
        });

        $('#page_course_select').html(options);

        const summary = res.summary || {};

        const labels = [
          "Courses",
          "Pages",
          "Assignments",
          "Discussions",
          "Gradebook",
          "Calendar",
          "Accounts"
        ];

        const values = [
          summary.courses || 0,
          summary.pages || 0,
          summary.assignments || 0,
          summary.discussions || 0,
          summary.gradebook || 0,
          summary.calendar || 0,
          summary.accounts || 0
        ];

        renderSummaryChart(labels, values);
      },

      error: function () {
        $('#page_course_select').html('<option>Error loading courses</option>');
      }
    });
  });

  $('#grade_user_select').on('change', function () {
    const userId = $(this).val();

    if (!userId) return;

    $('#course_select').html('<option value="">Loading courses...</option>');

    $.ajax({
      url: '/accounts/courses',   
      method: 'GET',
      data: { user_id: userId },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (res) {

        let data = res.courses;

        let options = '<option value="">Select Course</option>';

        $.each(data, function (i, course) {
          options += `<option value="${course.id}">${course.name}</option>`;
        });

        $('#course_select').html(options);
      },

      error: function () {
        $('#course_select').html('<option>Error loading courses</option>');
      }
    });
  });

  $('#page_course_select').on('change', function () {

    const courseId = $(this).val();
    const userId = $('#user_select').val();

    if (!courseId || !userId) return;

    loadWeeklyPageViews(courseId, userId);
    loadAssignmentAnalytics(courseId);
  });

  $('#course_select').on('change', function () {
    const courseId = $(this).val();

    if (!courseId) return;

    loadAssignmentAnalytics(courseId);
  });
</script>

<script>
  let chartInstance = null;

  $("#graph_btn").click(function () {

    const courseId = $("#course_select").val();
    const userId = $("#grade_user_select").val();

    if (!courseId) {
      alert("Please select a course");
      return;
    }

    document.getElementById("table_views").style.display = "none";

    $("#graph_container")
      .show()
      .html('<canvas id="assignmentChart"></canvas>');

    $.ajax({
      url: '/accounts/assignment_analytics',
      method: "GET",
      data: { course_id: courseId, user_id: userId },
      headers: {
        "ngrok-skip-browser-warning": "true"
      },

      success: function (data) {

        console.log("API RESPONSE:", data); // ✅ debug

        if (data.errors) {
          $("#graph_container").html(data.errors[0].message);
          return;
        }

        if (!Array.isArray(data) || data.length === 0) {
          $("#graph_container").html("No data available");
          return;
        }

        let labels = [];
        let scores = [];
        let maxScores = [];

        data.forEach(a => {

          if (!a.title) return;

          labels.push(a.title);

          scores.push(a.submission?.score ?? 0);
          maxScores.push(a.max_score ?? 0);
        });

        if (labels.length === 0) {
          $("#graph_container").html("No valid data");
          return;
        }

        renderChart(labels, scores, maxScores);
      },

      error: function (err) {
        console.error(err);
        $("#graph_container").html("Error loading chart");
      }
    });
  });


  function renderChart(labels, scores, maxScores) {

    const canvas = document.getElementById("assignmentChart");

    if (!canvas) return;

    const ctx = canvas.getContext("2d");

    if (chartInstance) {
      chartInstance.destroy();
    }

    chartInstance = new Chart(ctx, {
      type: "bar",
      data: {
        labels: labels,
        datasets: [
          {
            label: "User Score",
            data: scores,
            borderWidth: 2
          },
          {
            label: "Max Score",
            data: maxScores,
            borderWidth: 2
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false, // ✅ FIX layout issues
        plugins: {
          legend: {
            display: true
          }
        },
        scales: {
          x: {
            ticks: {
              maxRotation: 45,
              minRotation: 45,
              autoSkip: false
            }
          },
          y: {
            beginAtZero: true
          }
        }
      }
    });
  }
</script>