<h2>Courses Detailed View</h2>

<style>
  table {
    border-collapse: collapse;
    width: 100%;
    font-size: 14px;
  }

  th {
    background-color: #f2f2f2;
  }

  th, td {
    border: 1px solid #ddd;
    padding: 8px;
    vertical-align: top;
    min-width: 100px;
  }

  tr:hover {
    background-color: #f9f9f9;
  }
</style>

<table>
  <thead>
    <tr>
      <% @courses.first.keys.each do |key| %>
        <th><%= key.humanize %></th>
      <% end %>
    </tr>
  </thead>

  <tbody>
    <% @courses.each do |course| %>
      <tr>
        <% course.each do |key, value| %>
          <td>
            <% if value.is_a?(Hash) %>
              <%# Handle nested hash like calendar %>
              <% value.each do |k, v| %>
                <b><%= k %>:</b> <%= v %><br>
              <% end %>

            <% elsif value.is_a?(Array) %>
              <%# Handle enrollments array %>
              <% value.each do |item| %>
                <div style="margin-bottom: 5px;">
                  <% item.each do |k, v| %>
                    <b><%= k %>:</b> <%= v %><br>
                  <% end %>
                </div>
                <hr>
              <% end %>

            <% else %>
              <%= value %>
            <% end %>
          </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>